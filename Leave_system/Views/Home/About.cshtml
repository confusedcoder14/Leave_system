@{
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>About Us - LeaveMS</title>

    <style>
        body {
            margin: 0;
            font-family: "Segoe UI", sans-serif;
            background: #f4f6f9;
        }

        /* HERO SECTION */
        .about-hero {
            background: linear-gradient(to right, #1e90ff, #0a3d62);
            color: white;
            padding: 80px 20px;
            text-align: center;
        }

            .about-hero h1 {
                font-size: 42px;
                margin-bottom: 10px;
            }

            .about-hero p {
                font-size: 18px;
                max-width: 700px;
                margin: auto;
                opacity: 0.9;
            }

        /* CONTENT SECTION */
        .about-content {
            max-width: 1100px;
            margin: 50px auto;
            padding: 0 20px;
        }

        .about-row {
            display: flex;
            gap: 30px;
            flex-wrap: wrap;
        }

        .about-box {
            flex: 1;
            background: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        }

            .about-box h2 {
                color: #0a3d62;
                margin-bottom: 15px;
            }

            .about-box p {
                color: #555;
                line-height: 1.7;
            }

        /* VALUES */
        .values {
            margin: 50px 0 110px;
            text-align: center;
        }

            .values h2 {
                margin-bottom: 30px;
                color: #0a3d62;
            }

        .value-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
        }

        .value-card {
            background: white;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        }

            .value-card h3 {
                margin-bottom: 10px;
                color: #1e90ff;
            }

            .value-card p {
                color: #555;
                font-size: 14px;
            }

    </style>
</head>
<body>

    <!-- HERO -->
    <section class="about-hero">
        <h1>About Leave Management System</h1>
        <p>
            LeaveMS is a smart and efficient platform designed to simplify
            employee leave management for organizations.
        </p>
    </section>

    <!-- MAIN CONTENT -->
    <section class="about-content">

        <div class="about-row">
            <div class="about-box">
                <h2>Who We Are</h2>
                <p>
                    LeaveMS is a modern web-based application that helps organizations
                    manage employee leave requests digitally. Our goal is to eliminate
                    paperwork and provide a transparent, fast and secure system.
                </p>
            </div>

            <div class="about-box">
                <h2>Our Mission</h2>
                <p>
                    Our mission is to make leave management simple, reliable and
                    accessible for both employees and administrators through
                    user-friendly design and secure technology.
                </p>
            </div>
        </div>

        <!-- VALUES -->
        <div class="values">
            <h2>Why Choose LeaveMS?</h2>

            <div class="value-cards">
                <div class="value-card">
                    <h3>Easy to Use</h3>
                    <p>Simple interface for employees and admins.</p>
                </div>

                <div class="value-card">
                    <h3>Secure</h3>
                    <p>Authentication and data protection built-in.</p>
                </div>

                <div class="value-card">
                    <h3>Time Saving</h3>
                    <p>Faster leave approvals and tracking.</p>
                </div>

                <div class="value-card">
                    <h3>Modern System</h3>
                    <p>Designed using latest web technologies.</p>
                </div>
            </div>
        </div>

    </section>

   
</body>
</html>

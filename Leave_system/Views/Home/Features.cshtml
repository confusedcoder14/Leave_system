@{
}


<!DOCTYPE html>
<html>
<head>
    <title>Features - LeaveMS</title>
    <style>
        body {
            margin: 0;
            font-family: "Segoe UI", sans-serif;
            background: #f4f6f9;
        }

        .hero {
            background: linear-gradient(to right, #1e90ff, #0a3d62);
            color: white;
            padding: 70px 20px;
            text-align: center;
        }

            .hero h1 {
                font-size: 40px;
            }

        .features-section {
            max-width: 1100px;
            margin: 50px auto;
            padding: 0 20px;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 25px;
        }

        .feature-card {
            background: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
        }

            .feature-card h3 {
                color: #1e90ff;
                margin-bottom: 10px;
            }

            .feature-card p {
                color: #555;
                line-height: 1.6;
            }

        
    </style>
</head>
<body>

    <div class="hero">
        <h1>System Features</h1>
        <p>Powerful features to manage employee leave efficiently</p>
    </div>

    <div class="features-section">
        <div class="features-grid">

            <div class="feature-card">
                <h3>Easy Leave Request</h3>
                <p>Employees can apply for leave online with minimal effort.</p>
            </div>

            <div class="feature-card">
                <h3>Admin Approval</h3>
                <p>Admins can approve or reject leave requests in real-time.</p>
            </div>

            <div class="feature-card">
                <h3>Leave History</h3>
                <p>Track previous, current and pending leave applications.</p>
            </div>

            <div class="feature-card">
                <h3>Role Based Access</h3>
                <p>Separate dashboards for Admin and Employees.</p>
            </div>

            <div class="feature-card">
                <h3>Secure Login</h3>
                <p>Authentication ensures data safety and privacy.</p>
            </div>

            <div class="feature-card">
                <h3>Responsive Design</h3>
                <p>Works smoothly on desktop, tablet and mobile devices.</p>
            </div>

        </div>
    </div>


</body>
</html>

@{

}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Leave Management System</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: "Segoe UI", sans-serif;
        }

        body {
            background-image: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), url('/images/signup-img.jpg');
            background-size: cover; /* full screen cover */
            background-repeat: no-repeat; /* repeat band */
            background-position: center;
        }


        .main-container {
            width: 95%;
            max-width: 900px;
            margin: 30px auto;
            display: flex;
            flex-wrap: wrap;
            background: #fff;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }

        /* LEFT PANEL */
        .left-panel {
            width: 40%;
            min-height: 250px;
            background: linear-gradient(rgba(128,0,128,0.7), rgba(0,0,0,0.7)), url("https://images.unsplash.com/photo-1520975916090-3105956dac38") center/cover;
            color: white;
            padding: 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .left-panel h2 {
            font-size: 36px;
            margin-bottom: 20px;
        }

        .left-panel p {
            font-size: 14px;
            opacity: 0.8;
        }

        /* RIGHT PANEL */
        .right-panel {
            width: 60%;
            padding: 40px 50px;
        }

        .form-group {
            margin-bottom: 15px;
        }

            .form-group label {
                font-size: 12px;
                font-weight: bold;
                color: #555;
            }

            .form-group input {
                width: 100%;
                padding: 8px;
                border: none;
                border-bottom: 2px solid #ccc;
                outline: none;
            }

                .form-group input:focus {
                    border-bottom: 2px solid #4CAF50;
                }

        /* BUTTON */
        .btn {
            width: 120px;
            padding: 10px;
            background: #3f51b5;
            color: white;
            border: none;
            border-radius: 4px;
            margin-top: 20px;
            cursor: pointer;
        }

            .btn:hover {
                background: #303f9f;
            }

        .login-text {
            margin-top: 15px;
            font-size: 13px;
        }

            .login-text a {
                text-decoration: none;
                color: #3f51b5;
                font-weight: bold;
            }

        /* GOOGLE SIGNUP BUTTON */
        .google-signup {
            margin-top: 15px;
            margin-bottom: 10px;
        }

            .google-signup a {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 10px;
                border: 1px solid #ddd;
                padding: 10px;
                border-radius: 4px;
                text-decoration: none;
                color: #555;
                font-size: 14px;
                font-weight: 500;
                background: #fff;
            }

            .google-signup img {
                width: 18px;
                height: 18px;
            }

            .google-signup a:hover {
                background: #f5f5f5;
            }


        .social-login {
            margin-top: 20px;
            display: flex;
            width: 100%;
        }

            .social-login a {
                flex: 1;
                text-align: center;
                padding: 12px 0;
                color: white;
                text-decoration: none;
                font-size: 14px;
                font-weight: 500;
            }

            .social-login .facebook {
                background: #3b5998;
                border-radius: 4px 0 0 4px;
            }

            .social-login .twitter {
                background: #55acee;
                border-radius: 0 4px 4px 0;
            }

            .social-login a:hover {
                opacity: 0.9;
            }

        /* MODAL */
        .modal {
            display: none;
            position: fixed;
            z-index: 999;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.6);
        }

        .modal-content {
            background: #fff;
            width: 350px;
            margin: 15% auto;
            padding: 30px;
            text-align: center;
            border-radius: 8px;
        }

            .modal-content h2 {
                color: #4CAF50;
                margin-bottom: 10px;
            }

        .modal-btn {
            background: #4CAF50;
            color: white;
            border: none;
            padding: 10px 25px;
            border-radius: 4px;
            cursor: pointer;
        }

        /* LOADER */
        .loader-overlay {
            display: none;
            position: fixed;
            z-index: 1000;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255,255,255,0.9);
            text-align: center;
            padding-top: 20%;
        }

        .spinner {
            width: 50px;
            height: 50px;
            border: 5px solid #ccc;
            border-top: 5px solid #4CAF50;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: auto;
        }

        @@keyframes spin {
            100% {
                transform: rotate(360deg);
            }
        }
        @@media (max-width: 768px) {

            .main-container {
                flex-direction: column; /* ✅ stack */
            }

            .left-panel {
                width: 100%;
                text-align: center;
                padding: 30px 20px;
            }

                .left-panel h2 {
                    font-size: 28px;
                }

            .right-panel {
                width: 100%;
                padding: 25px;
            }

            .form-group {
                width: 100%;
            }

            .btn {
                width: 100%; /* full button */
            }

            .social-login {
                flex-direction: column;
                gap: 10px;
            }

                .social-login a {
                    border-radius: 6px !important;
                }
        }
    </style>

</head>
<body>

    <div class="main-container">

        <!-- LEFT IMAGE SECTION -->
        <div class="left-panel">
            <h2>Sign Up</h2>
            <p>Privacy policy & Terms of service</p>
        </div>

        <!-- RIGHT FORM SECTION -->
        <div class="right-panel">
            @{
                ViewData["Title"] = "Sign Up";
            }
            <h2>Sign Up</h2>
            @if (ViewBag.Error != null)
            {
                <div style="color:red;    text-align: center;">@ViewBag.Error</div>
            }
            <form asp-action="SignUp" method="post" autocomplete="off">
                @Html.AntiForgeryToken()
                <div class="row">
                    <div class="form-group col-sm-12 col-md-6 col-lg-6">
                        <label>First Name</label>
                        <input type="text" id="firstname" name="FirstName" placeholder="Enter First Name" autocomplete="off">
                    </div>

                    <div class="form-group col-sm-12 col-md-6 col-lg-6">
                        <label>Last Name</label>
                        <input type="text" id="lastname" name="LastName" placeholder="Enter Last Name" autocomplete="off">
                    </div>

                    <div class="form-group col-sm-12 col-md-6 col-lg-6">
                        <label>Phone No</label>
                        <input type="text" id="phone" name="Phone" placeholder="Enter Phone Number" autocomplete="off">
                    </div>

                    <div class="form-group col-sm-12 col-md-6 col-lg-6">
                        <label>Email</label>
                        <input type="email" id="email" name="Email" placeholder="Enter Email" autocomplete="off">
                    </div>

                    <div class="form-group col-sm-12 col-md-6 col-lg-6">
                        <label>Password</label>
                        <input type="password" id="password" name="Password" placeholder="********" autocomplete="off">
                    </div>

                    <div class="form-group col-sm-12 col-md-6 col-lg-6">
                        <label>Confirm Password</label>
                        <input type="password" id="confirmPassword" name="confirmPassword" placeholder="********" autocomplete="new-password">
                    </div>

                    <button type="submit" class="btn">Sign Up</button>

                    <p class="login-text">
                        Already have an account?
                        <a href="/Home/Login">Sign In</a>
                    </p>

                    <div class="google-signup">
                        <a href="#">
                            <img src="https://images.icon-icons.com/730/PNG/96/google_icon-icons.com_62798.png" alt="Google">
                            <span>Sign up with Google</span>
                        </a>
                    </div>


                    <div class="social-login">
                        <a href="#" class="facebook">
                            <span>Connect with Facebook</span>
                        </a>
                        <a href="#" class="twitter">
                            <span>Connect with Twitter</span>
                        </a>
                    </div>


                </div>
            </form>
            <!-- SUCCESS MODAL -->
            <div id="successModal" class="modal">
                <div class="modal-content">
                    <h2>🎉 Signup Successful!</h2>
                    <p>Your account has been created successfully.</p>
                    <button onclick="startLoader()" class="modal-btn">Done</button>
                </div>
            </div>

        </div>

    </div>
    <!-- LOADER -->
    <div id="loader" class="loader-overlay">
        <div class="spinner"></div>
        <p>Redirecting to Login...</p>
    </div>
    <script>
        // Show success modal if signup successful
        window.onload = function () {
            var success = '@ViewBag.Success';
            if (success === 'True') {
                document.getElementById("successModal").style.display = "block";
            }
        }

        function startLoader() {
            document.getElementById("successModal").style.display = "none";
            document.getElementById("loader").style.display = "block";

            setTimeout(function () {
                window.location.href = "/Home/Login";
            }, 2500);
        }
    </script>

</body>
</html>

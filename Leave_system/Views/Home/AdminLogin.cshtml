@{
    Layout = null;
}

<!DOCTYPE html>
<html>

<head>
    <title>Admin Login</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #6195adba;
            font-family: 'Arial';
            background-image: url('/images/kyc.webp');
            background-size: cover; 
            background-repeat: no-repeat; 
            background-position: center;
        }

        .imgcontainer {
            text-align: center;
            margin: 24px 0 12px 0;
        }

        img.avatar {
            width: 10%;
            border-radius: 50%;
        }


        .login {
            width: 382px;
            overflow: hidden;
            margin: auto;
            margin: 20 0 0 450px;
            padding: 80px;
            background: rgba(244, 243, 243, 0.619);
            border-radius: 15px;
            backdrop-filter: blur(4px);
            display: flex;
            justify-content: center;
        }

        h2 {
            text-align: center;
            color: #ffffff;
            padding: 20px;
        }

        label {
            color: #8d4444;
            font-size: 17px;
        }

        #Admin {
            width: 300px;
            height: 30px;
            border: none;
            border-radius: 3px;
            padding-left: 8px;
        }

        #Password {
            width: 300px;
            height: 30px;
            border: none;
            border-radius: 3px;
            padding-left: 8px;
        }

        #log {
            width: 300px;
            height: 30px;
            border: none;
            border-radius: 50px;
            padding: 6px 0px 0px;
            color: rgb(0, 0, 0);
            font-size: 15px;
            font-weight: bold;
            text-align: center;
            font-size: 20px;
            background-color: #2e9a43;
        }

            #log:hover {
                background-color: aquamarine;
                cursor: pointer;
            }


        span {
            color: rgb(20, 13, 13);
            font-size: 17px;
        }

        a {
            float: left;
            color: rgb(192, 0, 0);
        }

        .rshift {
            display: flex;
            justify-content: end;
        }

        h1 {
            color: white;
            text-align: right;
            letter-spacing: 4px;
        }

        .head-back {
            height: 80px;
            background-color: #6234ec62;
            backdrop-filter: blur(4px);
        }

        .admin-heading {
            color: black;
            font-size: 23px;
            margin-top: -15%;
            text-align: left;
            align-items: left;
            text-decoration: none;
            font-weight: 600;
            border: none;
            border-bottom: 1px solid #555;
        }

        .user-heading {
            text-align: right;
            align-items: right;
            margin-left: 60%;
            margin-top: -15%;
            text-decoration: none;
            font-size: 23px;
            font-weight: 600;
            color: black;
            border: none;
            border-bottom: 1px solid #555;
        }
    </style>
</head>

<body>
    <div class="head-back">
        <marquee behavior="Alternate">
            <h1>
                Leave Management System &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;Leave Management
                System&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; Leave Management System
            </h1>
            <br>
        </marquee>
    </div>
    <div class="imgcontainer">
        <img src="~/images/avatar.jpg" alt="Avatar" class="avatar">
    </div>
    <div class="login">
        <form id="login" onsubmit="auth()">
            <a href="@Url.Action("Login", "Home")" class="user-heading">User Login</a>
            <a href="@Url.Action("AdminLogin", "Home")" class="admin-heading">Admin Login</a>
            <a href="@Url.Action("Login", "Home")" class="user-heading">User Login</a>
            <br>
            <br>
            <label>
                <b>Admin name</b>
            </label>
            <input type="text" name="Admin" id="Admin" required placeholder="Admin Id">
            <br><br>
            <label>
                <b>
                    Password
                </b>
            </label>
            <input type="Password" name="password" id="Password" required placeholder="Password">
            <br><br>
            <a onclick="auth()" class="submit-btn" name="log" id="log" value="Log In">Log In</a>
            <br><br>
            <br><br>
            <input type="checkbox" id="check">
            <span>Remember me</span>
            <br><br>
            <div class="ishift"><a href="/">← Back to Home</a></div>
            <div class="rshift"><a href="@Url.Action("ForgotPass", "Home")">Forgot Password</a></div>
        </form>
    </div>
    <script>
        function auth() {

            var Username = document.getElementById("Admin").value;
            var Password = document.getElementById("Password").value;

            if (Username === "admin" && Password === "password") {
                location.assign(`@Url.Action("Admin", "Home")`)
                alert("Login successful")
            }
            else {
                alert("Invalid. Please try again.");
            }
        }
    </script>
</body>

</html>
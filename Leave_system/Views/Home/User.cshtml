@{
    Layout = null;
}

@model Leave_system.Models.User;

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Employee Dashboard</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link href="https://unpkg.com/@@tabler/icons/iconfont/tabler-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="~/css/user.css" rel="stylesheet" />
</head>

<body>
    <div class="dashboard">
        <div class="headerrr">
            <div>
                <div class="heading">Employee Dashboard</div>
                <div class="breadcrumb">
                    <a href="/Home/User" class="breadcrumb-link">Dashboard</a> / Employee Dashboard
                </div>
            </div>

            <!-- Logout Button 
            <button class="logout-btn" onclick="window.location.href='@Url.Action("Login", "Home")'">Logout</button>-->
            <a href="/Home/Logout" class="logout-btn">Logout</a>

        </div>
        <div class="alert" id="leaveAlert">
            Your Leave Request on <strong id="currentDate"></strong> has been Approved!!!
            <span class="close-alert" onclick="hideAlert()">✕</span>
        </div>

        <div class="grid">
            @{
                if(Model!=null)
                {
                    <div class="card profile-card">
                        <div class="profile-header" style="position: relative;">
                            <img src="~/images/profile.jpg" />
                            <div>
                                <h2 id="nameDisplay">@Model.FirstName @Model.LastName</h2>
                                <p id="roleDisplay">Full stack Developer</p>
                            </div>
                            <button type="button" id="editBtn" class="btn-edit" style="position: absolute; top: 15px; right: 15px;">Edit</button>
                        </div>

                        <div class="info">
                            <p><strong>Phone Number:</strong> <span id="phoneDisplay">@Model.Phone</span></p>
                            <p><strong>Email Address:</strong> <span id="emailDisplay">@Model.Email</span></p>
                            <p><strong>Office Location:</strong> <span id="locationDisplay">@Model.Location</span></p>
                            <p><strong>Joined On:</strong> <span id="joinedDisplay">@Model.JoinedOn.ToString("dd MMM yyyy")</span></p>
                        </div>
                    </div>
                }
            }
            <!-- Profile Card -->
            

            <!-- Donut Chart + Leave Details -->
            <div class="card leave-card">
                <div class="leave-header">
                    <span>Leave Details</span>
                    <div class="year-dropdown">
                        <button class="year-btn" id="yearButton">📅 2024</button>
                        <div class="dropdown-menu" id="yearMenu">
                            <button onclick="selectYear(2023)">2023</button>
                            <button onclick="selectYear(2024)">2024</button>
                            <button onclick="selectYear(2025)">2025</button>
                        </div>
                    </div>
                </div>
                <div class="donut-card">
                    <div class="legend">
                        <div><span style="background:#003f5c;"></span>1254 on time</div>
                        <div><span style="background:#2f4b7c;"></span>32 Late Attendance</div>
                        <div><span style="background:#ffa600;"></span>658 Work From Home</div>
                        <div><span style="background:#ff6361;"></span>14 Absent</div>
                        <div><span style="background:#bc5090;"></span>68 Sick Leave</div>
                    </div>
                    <div class="donut-chart"></div>
                </div>
                <div class="text-below">
                    <span>Better than <strong>85% </strong> of Employees</span>
                </div>
            </div>

            <!-- Right Leave Summary -->
            <div class="card right-card">
                <div class="leave-header">
                    <span>Leave Details</span>
                    <div class="year-dropdown">
                        <button class="year-btn" id="yearButton">📅 2024</button>
                        <div class="dropdown-menu" id="yearMenu">
                            <button onclick="selectYear(2023)">2023</button>
                            <button onclick="selectYear(2024)">2024</button>
                            <button onclick="selectYear(2025)">2025</button>
                        </div>
                    </div>
                </div>
                <div class="stats">
                    <div><span class="value">16</span>Total Leaves</div>
                    <div><span class="value">10</span>Taken</div>
                    <div><span class="value">2</span>Absent</div>
                    <div><span class="value">0</span>Request</div>
                    <div><span class="value">240</span>Worked Days</div>
                    <div><span class="value">2</span>Loss of Pay</div>
                </div>
                <a href="#" class="btn" id="openFormBtn">Apply New Leave</a>
            </div>

        </div>

    </div>

    <div class="container">

        <!-- Attendance Box -->
        <!-- Attendance Box -->
        <div class="card attendance-box">
            <h3>Attendance</h3>
            <div class="time"><span id="currentTime"></span></div>

            <div class="circle">
                <div class="label">Total Hours</div>
                <div class="time" id="elapsed">00:00:00</div>
            </div>

            <div class="production" id="production">Production : 0.00 hrs</div>

            <div class="punch-info" id="punchInfo">🔖 Not Punched In</div>

            <button class="punch-out" id="punchBtn" onclick="handlePunch()">Punch In</button>
        </div>

        <!-- Success Modal -->
        <div class="modal" id="successModal" style="display: none;">
            <div class="modal-content">
                <h2 id="modalTitle">✅ Punch In Successful</h2>
                <p>Your <span id="actionType">Punch In</span> Time was <strong id="modalTime">--:--</strong></p>
                <button class="close-modal" onclick="closeModal()">Close</button>
            </div>
        </div>

        <!-- Stat Cards -->
        <div class="info1">
            <div class="info-cards">
                <div class="info-card">
                    <div class="icon orange"><i class="ti ti-calendar-up" style="font-size: 24px;"></i></div>
                    <div class="value">8.36 / 9</div>
                    <p>Total Hours Today</p>
                    <p class="note">⬆️ 5% This Week</p>
                </div>
                <div class="info-card">
                    <div class="icon gray"><i class="ti ti-calendar-up"></i></div>
                    <div class="value">10 / 40</div>
                    <p>Total Hours Week</p>
                    <p class="note">⬇️ 6% Last Week</p>
                </div>
                <div class="info-card">
                    <div class="icon blue"><i class="ti ti-calendar-up"></i></div>
                    <div class="value">75 / 98</div>
                    <p>Total Hours Month</p>
                    <p class="note">🔻 8% Last Month</p>
                </div>
                <div class="info-card">
                    <div class="icon pink"><i class="ti ti-calendar-up"></i></div>
                    <div class="value">16 / 28</div>
                    <p>Overtime this Month</p>
                    <p class="note">🔽 6% Last Month</p>
                </div>
            </div>

            <!-- Timeline Card -->
            <div class="card timeline-card">
                <div class="timeline-header">
                    <span>⚪ Total Working Hours <strong>12h 36m</strong></span>
                    <span>🟢 Productive Hours <strong>08h 36m</strong></span>
                    <span>🟡 Break hours <strong>22m 15s</strong></span>
                    <span>🔵 Overtime <strong>02h 15m</strong></span>
                </div>
                <div class="timeline-progress">
                    <div class="block green" style="width: 35%"></div>
                    <div class="block yellow" style="width: 10%"></div>
                    <div class="block green" style="width: 30%"></div>
                    <div class="block yellow" style="width: 10%"></div>
                    <div class="block green" style="width: 8%"></div>
                    <div class="block blue" style="width: 7%"></div>
                </div>
                <div class="timeline-labels">
                    <span>00:00</span>
                    <span>02:00</span>
                    <span>04:00</span>
                    <span>06:00</span>
                    <span>08:00</span>
                    <span>10:00</span>
                    <span>12:00</span>
                </div>
            </div>
        </div>
    </div>


    <div class="dashboard-section">

        <!-- Performance Section -->
        <div class="performance-area card-box">
            <div class="area-header">
                <div class="header-title">Performance</div>
                <div class="year-tag">📅 2024</div>
            </div>
            <div class="performance-metrics">
                <div class="performance-score">
                    <span style="color:#007bff;">98%</span>
                    <span class="growth-rate">12%</span>
                    <span style="font-weight:400;">vs last years</span>
                </div>
                <div class="analytics-chart">
                    <canvas id="lineChart" height="200"></canvas>
                </div>
            </div>
        </div>

        <!-- Skills Section -->
        <div class="skills-area card-box">
            <div class="area-header">
                <div class="header-title">My Skills</div>
                <div class="year-tag">📅 2024</div>
            </div>
            <div class="skills-list-container">
                <div class="skill-card">
                    <div class="skill-details">
                        <div class="skill-name">🟠 Figma</div>
                        <div class="skill-date">Updated : 15 May 2025</div>
                    </div>
                    <div class="skill-percent">95%</div>
                </div>
                <div class="skill-card">
                    <div class="skill-details">
                        <div class="skill-name">🟢 HTML</div>
                        <div class="skill-date">Updated : 12 May 2025</div>
                    </div>
                    <div class="skill-percent">85%</div>
                </div>
                <div class="skill-card">
                    <div class="skill-details">
                        <div class="skill-name">🟣 CSS</div>
                        <div class="skill-date">Updated : 12 May 2025</div>
                    </div>
                    <div class="skill-percent">70%</div>
                </div>
                <div class="skill-card">
                    <div class="skill-details">
                        <div class="skill-name">🔵 Wordpress</div>
                        <div class="skill-date">Updated : 15 May 2025</div>
                    </div>
                    <div class="skill-percent">61%</div>
                </div>
                <div class="skill-card">
                    <div class="skill-details">
                        <div class="skill-name">⚫ Javascript</div>
                        <div class="skill-date">Updated : 13 May 2025</div>
                    </div>
                    <div class="skill-percent">58%</div>
                </div>
            </div>
        </div>

        <!-- Right Sidebar -->
        <div class="sidebar-widgets">

            <!-- Birthday Widget -->
            <div class="birthday-widget">
                <div class="header-title">Team Birthday</div>
                <img src="https://i.pravatar.cc/100?img=5" alt="avatar" class="birthday-image" />
                <div class="employee-name">Shivam Tiwari</div>
                <div class="employee-position">DotNet Developer</div>
                <button class="wish-button">Send Wishes</button>
            </div>

            <!-- Leave Policy -->
            <div class="summary-card update-widget">
                <div>
                    <div class="card-label">Leave Policy</div>
                    <div class="card-info">Last Updated : Today</div>
                </div>
                <button class="view-button" onclick="openPolicy()">View All</button>
            </div>

            <!-- Next Holiday -->
            <div class="summary-card holiday-widget">
                <div>
                    <div class="card-label">Next Holiday</div>
                    <div class="card-info" id="nextHolidayText">Loading...</div>
                </div>
                <button class="view-button" onclick="openHolidayModal()">View All</button>
            </div>

        </div>

    </div>
    
    <div id="editModal">
        <div class="modal-box">
            <h3>Edit Profile</h3>
            <button id="closeModal" class="close-btn">✖</button>

            <form id="editProfileForm">
                <input type="hidden" id="userId" value="@Model.Id" />

                <label>First Name</label>
                <input type="text" id="firstNameInput" class="form-control" />

                <label>Last Name</label>
                <input type="text" id="lastNameInput" class="form-control" />

                <label>Phone</label>
                <input type="text" id="phoneInput" class="form-control" />

                <label>Email</label>
                <input type="text" id="emailInput" class="form-control" />

                <label>Location</label>
                <input type="text" id="locationInput" class="form-control" />

                <!-- VERY IMPORTANT -->
                <button type="submit" id="saveBtn">Save</button>
            </form>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const editBtn = document.getElementById("editBtn");
            const editModal = document.getElementById("editModal");
            const closeModal = document.getElementById("closeModal");
            const form = document.getElementById("editProfileForm");

            // OPEN MODAL + PREFILL DATA
            editBtn.addEventListener("click", function () {

                document.getElementById("firstNameInput").value =
                    document.getElementById("nameDisplay").innerText.split(" ")[0];

                document.getElementById("lastNameInput").value =
                    document.getElementById("nameDisplay").innerText.split(" ")[1] || "";

                document.getElementById("phoneInput").value =
                    document.getElementById("phoneDisplay").innerText;

                document.getElementById("emailInput").value =
                    document.getElementById("emailDisplay").innerText;

                document.getElementById("locationInput").value =
                    document.getElementById("locationDisplay").innerText;

                editModal.style.display = "flex";
            });

            // CLOSE MODAL
            closeModal.addEventListener("click", function () {
                editModal.style.display = "none";
            });

            // SAVE PROFILE
            form.addEventListener("submit", function (e) {
                e.preventDefault();

                const data = {
                    Id: document.getElementById("userId").value,
                    FirstName: document.getElementById("firstNameInput").value,
                    LastName: document.getElementById("lastNameInput").value,
                    Phone: document.getElementById("phoneInput").value,
                    Email: document.getElementById("emailInput").value,
                    Location: document.getElementById("locationInput").value
                };

                fetch('/Home/UpdateProfile', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                })
                .then(res => res.json())
                .then(res => {
                    if (res.success) {

                        // UPDATE PROFILE CARD
                        document.getElementById("nameDisplay").innerText =
                            data.FirstName + " " + data.LastName;

                        document.getElementById("phoneDisplay").innerText = data.Phone;
                        document.getElementById("emailDisplay").innerText = data.Email;
                        document.getElementById("locationDisplay").innerText = data.Location;

                        // CLOSE MODAL
                        editModal.style.display = "none";
                    }
                    else {
                        alert(res.message);
                    }
                })
                .catch(err => {
                    console.log(err);
                    alert("Server error");
                });
            });

        });
    </script>


    <!-- LEAVE POLICY MODAL -->
    <div id="policyModal" class="modal">
        <div class="modal-content">

            <span class="close-btn" onclick="closePolicy()">&times;</span>

            <h2>Leave Policy</h2>

            <div class="policy-section">
                <h4>Casual Leave</h4>
                <p>12 casual leaves per year. Prior approval required.</p>
            </div>

            <div class="policy-section">
                <h4>Sick Leave</h4>
                <p>10 sick leaves per year. Medical certificate required for more than 2 days.</p>
            </div>

            <div class="policy-section">
                <h4>Earned Leave</h4>
                <p>Accumulates monthly. Maximum carry forward: 30 days.</p>
            </div>

            <div class="policy-section">
                <h4>Maternity / Paternity Leave</h4>
                <p>Provided as per government and company norms.</p>
            </div>

            <div class="policy-section">
                <h4>Approval Rules</h4>
                <ul>
                    <li>Manager approval mandatory</li>
                    <li>Admin has final authority</li>
                    <li>Emergency leave must be informed</li>
                </ul>
            </div>

        </div>
    </div>


    <!-- Form Popup -->
    <div class="overlay" id="formOverlay">
        <div class="form-box">
            <h2>Apply for Leave</h2>
            <p class="subtitle">Submit a new leave request for approval</p>

            <form id="leaveForm">
                <div class="form-row">
                    <input type="hidden" name="FirstName" value="@Model.FirstName" />
                    <input type="hidden" name="LastName" value="@Model.LastName" />

                    <div class="form-group">
                        <label>Leave Type</label>
                        <select name="LeaveType" id="leaveType" required>
                            <option value="">Select leave type</option>
                            <option value="casual">Casual Leave</option>
                            <option value="sick">Sick Leave</option>
                            <option value="personal">Personal Leave</option>
                            <option value="maternity">Maternity Leave</option>
                            <option value="paternity">Paternity Leave</option>
                            <option value="emergency">Emergency Leave</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Emergency Contact</label>
                        <input name="EmergencyContact" type="text" id="contact" placeholder="Phone number" required >
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Start Date</label>
                        <input name="StartDate" type="date" id="startDate" required>
                    </div>

                    <div class="form-group">
                        <label>End Date</label>
                        <input name="EndDate" type="date" id="endDate" required>
                    </div>
                </div>

                <div class="form-group full">
                    <label>Reason for Leave</label>
                    <textarea name="Reason" id="reason" placeholder="Please provide details..." required></textarea>
                </div>

                <div class="form-actions">
                    <button type="submit" class="submit-btn">Submit Application</button>
                    <button type="button" class="draft-btn" onclick="closeForm()">Cancel</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        document.getElementById("leaveForm").addEventListener("submit", function(e) {
            e.preventDefault();
            const formData = new FormData(this);

            fetch("/Home/ApplyLeave", { method: "POST", body: formData })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        alert("Leave Applied Successfully");
                        this.reset();
                    } else {
                        alert(data.message || "Form submission failed");
                    }
                })
                .catch(err => {
                    alert("Form submission failed due to server error");
                    console.error(err);
                });
        });
    </script>



    <!-- Form-popup-Success Modal -->
    <div class="overlay success-modal" id="submitModal">
        <div class="success-message">
            <h3>✅ Your application has been submitted!</h3>
            <button class="close-btn" onclick="closeSuccessModal()">Close</button>
        </div>
    </div>


    <!-- Holiday-Modal Section -->
    <div class="modal-overlay" id="holidayModal">
        <div class="holiday-modal">
            <div class="modal-header">
                <h3>India Government Holidays 2025</h3>
                <button class="modal-close" onclick="closeHolidayModal()">Close</button>
            </div>
            <div id="holidayContent"></div>
        </div>
    </div>

  

    <!-- Modal -->
    <div class="modal" id="successModal">
        <div class="modal-content">
            <h2>✅ Punch Out Successful</h2>
            <p>Your Punch In Time was <strong id="punchInTime">10:00 AM</strong></p>
            <button class="close-modal" onclick="closeModal()">Close</button>
        </div>
    </div>

    <script>
        function openPolicy() {
            document.getElementById("policyModal").style.display = "block";
        }

        function closePolicy() {
            document.getElementById("policyModal").style.display = "none";
        }

        // Close popup when clicking outside
        window.onclick = function (event) {
            var modal = document.getElementById("policyModal");
            if (event.target == modal) {
                modal.style.display = "none";
            }
        }
    </script>


    <script>

        const btn = document.getElementById("yearButton");
        const menu = document.getElementById("yearMenu");

        // Toggle the dropdown menu
        btn.addEventListener("click", function () {
          menu.classList.toggle("show");
        });

        // Select a year and change the button label
        function selectYear(year) {
          btn.innerText = `📅 ${year}`;
          menu.classList.remove("show");
        }

        // Close the dropdown if clicked outside
        window.addEventListener("click", function (e) {
          if (!btn.contains(e.target) && !menu.contains(e.target)) {
            menu.classList.remove("show");
          }
        });

        // Format today's date (e.g., 21st September 2025)
        function formatDateWithSuffix(date) {
          const day = date.getDate();
          const month = date.toLocaleString('default', { month: 'long' });
          const year = date.getFullYear();

          // Get suffix like st, nd, rd, th
          const suffix =
            day === 1 || day === 21 || day === 31 ? 'st' :
              day === 2 || day === 22 ? 'nd' :
                day === 3 || day === 23 ? 'rd' : 'th';

          return `${day}${suffix} ${month} ${year}`;
        }

        // Populate the date in the alert
        document.addEventListener('DOMContentLoaded', () => {
          const today = new Date();
          document.getElementById('currentDate').textContent = formatDateWithSuffix(today);
        });

        // Close alert when clicking ✕
        function hideAlert() {
          document.getElementById('leaveAlert').style.display = 'none';
        }


        // Attendance Punch In/Out Logic
        document.addEventListener("DOMContentLoaded", () => {
          const currentTimeEl = document.getElementById("currentTime");
          const elapsedEl = document.getElementById("elapsed");
          const punchBtn = document.getElementById("punchBtn");
          const punchInfo = document.getElementById("punchInfo");
          const modal = document.getElementById("successModal");
          const modalTitle = document.getElementById("modalTitle");
          const actionType = document.getElementById("actionType");
          const modalTime = document.getElementById("modalTime");
          const production = document.getElementById("production");

          let timerInterval = null;

          // Format current date & time
          function formatNow() {
            const now = new Date();
            const options = { day: '2-digit', month: 'short', year: 'numeric' };
            return now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) +
              ', ' + now.toLocaleDateString('en-GB', options);
          }

          // Format milliseconds to HH:MM:SS
          function formatDuration(ms) {
            const sec = Math.floor(ms / 1000);
            const h = String(Math.floor(sec / 3600)).padStart(2, '0');
            const m = String(Math.floor((sec % 3600) / 60)).padStart(2, '0');
            const s = String(sec % 60).padStart(2, '0');
            return `${h}:${m}:${s}`;
          }

          // When modal opens
          function openModal(type, timeStr) {
            modal.style.display = 'flex';
            modalTitle.textContent = type === 'in' ? '✅ Punch In Successful' : '✅ Punch Out Successful';
            actionType.textContent = type === 'in' ? 'Punch In' : 'Punch Out';
            modalTime.textContent = timeStr;
          }

          function closeModal() {
            modal.style.display = 'none';
          }

          window.closeModal = closeModal;

          // Start timer
          function startTimer() {
            clearInterval(timerInterval);
            timerInterval = setInterval(() => {
              const now = Date.now();
              const punchIn = parseInt(localStorage.getItem('punchInTime'));
              const diff = now - punchIn;
              elapsedEl.textContent = formatDuration(diff);
            }, 1000);
          }

          // Stop timer
          function stopTimer() {
            clearInterval(timerInterval);
          }

          // Main punch button click
          window.handlePunch = function () {
            const isPunchedIn = localStorage.getItem('isPunchedIn') === 'true';

            if (!isPunchedIn) {
              // Punch In
              const time = new Date();
              const timestamp = time.getTime();
              const timeStr = time.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

              localStorage.setItem('punchInTime', timestamp);
              localStorage.setItem('isPunchedIn', 'true');

              punchBtn.textContent = "Punch Out";
              punchInfo.innerHTML = `🔖 Punched In at <strong>${timeStr}</strong>`;
              elapsedEl.textContent = "00:00:00";
              openModal('in', timeStr);
              startTimer();
            } else {
              // Punch Out
              const punchInTime = parseInt(localStorage.getItem('punchInTime'));
              const now = Date.now();
              const duration = now - punchInTime;
              const timeStr = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

              // Set production time
              const hoursWorked = (duration / 3600000).toFixed(2); // in hrs to 2 decimal
              production.textContent = `Production : ${hoursWorked} hrs`;

              // Update Punch Info
              punchInfo.innerHTML = `🔖 Punched Out at <strong>${timeStr}</strong>`;

              // Clear all
              stopTimer();
              localStorage.removeItem('punchInTime');
              localStorage.setItem('isPunchedIn', 'false');

              punchBtn.textContent = "Punch In";
              openModal('out', timeStr);
            }
          }

          // On page load
          currentTimeEl.textContent = formatNow();

          const isPunchedIn = localStorage.getItem('isPunchedIn') === 'true';
          if (isPunchedIn && localStorage.getItem('punchInTime')) {
            // Resume state
            punchBtn.textContent = "Punch Out";
            const punchIn = parseInt(localStorage.getItem('punchInTime'));
            const timeStr = new Date(punchIn).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            punchInfo.innerHTML = `🔖 Punched In at <strong>${timeStr}</strong>`;
            startTimer();
          } else {
            punchBtn.textContent = "Punch In";
            elapsedEl.textContent = "00:00:00";
            production.textContent = "Production : 0.00 hrs";
          }
        });



        // Leave Form Logic

        const openFormBtn = document.getElementById('openFormBtn');
        const formOverlay = document.getElementById('formOverlay');
        const leaveForm = document.getElementById('leaveForm');
        const successModal = document.getElementById('submitModal');

        openFormBtn.addEventListener('click', (e) => {
          e.preventDefault();
          formOverlay.style.display = 'flex';
        });

        leaveForm.addEventListener('submit', function (e) {
          e.preventDefault();

          // Simple manual validation
          let isValid = true;
          const inputs = leaveForm.querySelectorAll('input, select, textarea');
          inputs.forEach(input => {
            if (!input.checkValidity()) {
              isValid = false;
              input.style.borderColor = 'red';
            } else {
              input.style.borderColor = '#ccc';
            }
          });

          if (isValid) {
            formOverlay.style.display = 'none';
            successModal.style.display = 'flex';
            leaveForm.reset();
          }
        });

        function closeForm() {
          formOverlay.style.display = 'none';
          leaveForm.reset();
        }

        function closeSuccessModal() {
          successModal.style.display = 'none';
        }




        const ctx = document.getElementById('lineChart').getContext('2d');
        const lineChart = new Chart(ctx, {
          type: 'line',
          data: {
            labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul'],
            datasets: [{
              label: 'Performance',
              data: [20, 20, 35, 35, 40, 60, 60],
              borderColor: '#22c55e',
              backgroundColor: 'rgba(34, 197, 94, 0.2)',
              tension: 0.4,
              fill: true
            }]
          },
          options: {
            plugins: { legend: { display: false } },
            scales: {
              y: { beginAtZero: true }
            }
          }
        });

        // 🗓 Sample 2025 Indian Holidays (you can add more)
        const holidays = [
          { date: '2025-01-26', name: 'Republic Day' },
          { date: '2025-03-17', name: 'Holi' },
          { date: '2025-04-10', name: 'Ram Navami' },
          { date: '2025-04-14', name: 'Ambedkar Jayanti' },
          { date: '2025-05-01', name: 'Labour Day' },
          { date: '2025-08-15', name: 'Independence Day' },
          { date: '2025-09-15', name: 'Milad-un-Nabi' },
          { date: '2025-10-02', name: 'Gandhi Jayanti' },
          { date: '2025-10-20', name: 'Dussehra' },
          { date: '2025-10-31', name: 'Diwali' },
          { date: '2025-12-25', name: 'Christmas' }
        ];

        const monthNames = ["January", "February", "March", "April", "May", "June",
          "July", "August", "September", "October", "November", "December"];

        function groupHolidaysByMonth(holidays) {
          const grouped = {};
          holidays.forEach(h => {
            const month = new Date(h.date).getMonth();
            if (!grouped[month]) grouped[month] = [];
            grouped[month].push(h);
          });
          return grouped;
        }

        function openHolidayModal() {
          const modal = document.getElementById('holidayModal');
          const content = document.getElementById('holidayContent');
          content.innerHTML = '';

          const grouped = groupHolidaysByMonth(holidays);

          Object.keys(grouped).forEach(monthIndex => {
            const monthHolidays = grouped[monthIndex];
            const monthBlock = document.createElement('div');
            const monthTitle = document.createElement('div');
            monthTitle.className = 'month-title';
            monthTitle.textContent = monthNames[monthIndex];
            monthBlock.appendChild(monthTitle);

            monthHolidays.forEach(holiday => {
              const day = new Date(holiday.date).toLocaleDateString('en-IN', {
                day: 'numeric', month: 'short', year: 'numeric', weekday: 'short'
              });
              const item = document.createElement('div');
              item.className = 'holiday-item';
              item.textContent = `${day} - ${holiday.name}`;
              monthBlock.appendChild(item);
            });

            content.appendChild(monthBlock);
          });

          modal.style.display = 'flex';
        }

        function closeHolidayModal() {
          document.getElementById('holidayModal').style.display = 'none';
        }

        function showNextHoliday() {
          const today = new Date();
          const upcoming = holidays.find(h => new Date(h.date) >= today);
          const displayText = upcoming ?
            `${upcoming.name}, ${new Date(upcoming.date).toLocaleDateString('en-IN', {
              day: 'numeric', month: 'short', year: 'numeric'
            })}` :
            'No upcoming holidays';
          document.getElementById('nextHolidayText').textContent = displayText;
        }

        // Initialize
        showNextHoliday();

    </script>

</body>

</html>
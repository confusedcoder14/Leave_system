    <!-- Modal -->
    <div class="modal" id="successModal">
        <div class="modal-content">
            <h2>✅ Punch Out Successful</h2>
            <p>Your Punch In Time was <strong id="punchInTime">10:00 AM</strong></p>
            <button class="close-modal" onclick="closeModal()">Close</button>
        </div>
    </div>



    <script>

        const btn = document.getElementById("yearButton");
        const menu = document.getElementById("yearMenu");

        // Toggle the dropdown menu
        btn.addEventListener("click", function () {
          menu.classList.toggle("show");
        });

        // Select a year and change the button label
        function selectYear(year) {
          btn.innerText = `📅 ${year}`;
          menu.classList.remove("show");
        }

        // Close the dropdown if clicked outside
        window.addEventListener("click", function (e) {
          if (!btn.contains(e.target) && !menu.contains(e.target)) {
            menu.classList.remove("show");
          }
        });

        // Format today's date (e.g., 21st September 2025)
        function formatDateWithSuffix(date) {
          const day = date.getDate();
          const month = date.toLocaleString('default', { month: 'long' });
          const year = date.getFullYear();

          // Get suffix like st, nd, rd, th
          const suffix =
            day === 1 || day === 21 || day === 31 ? 'st' :
              day === 2 || day === 22 ? 'nd' :
                day === 3 || day === 23 ? 'rd' : 'th';

          return `${day}${suffix} ${month} ${year}`;
        }

        // Populate the date in the alert
        document.addEventListener('DOMContentLoaded', () => {
          const today = new Date();
          document.getElementById('currentDate').textContent = formatDateWithSuffix(today);
        });

        // Close alert when clicking ✕
        function hideAlert() {
          document.getElementById('leaveAlert').style.display = 'none';
        }


        // Attendance Punch In/Out Logic
        document.addEventListener("DOMContentLoaded", () => {
          const currentTimeEl = document.getElementById("currentTime");
          const elapsedEl = document.getElementById("elapsed");
          const punchBtn = document.getElementById("punchBtn");
          const punchInfo = document.getElementById("punchInfo");
          const modal = document.getElementById("successModal");
          const modalTitle = document.getElementById("modalTitle");
          const actionType = document.getElementById("actionType");
          const modalTime = document.getElementById("modalTime");
          const production = document.getElementById("production");

          let timerInterval = null;

          // Format current date & time
          function formatNow() {
            const now = new Date();
            const options = { day: '2-digit', month: 'short', year: 'numeric' };
            return now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) +
              ', ' + now.toLocaleDateString('en-GB', options);
          }

          // Format milliseconds to HH:MM:SS
          function formatDuration(ms) {
            const sec = Math.floor(ms / 1000);
            const h = String(Math.floor(sec / 3600)).padStart(2, '0');
            const m = String(Math.floor((sec % 3600) / 60)).padStart(2, '0');
            const s = String(sec % 60).padStart(2, '0');
            return `${h}:${m}:${s}`;
          }

          // When modal opens
          function openModal(type, timeStr) {
            modal.style.display = 'flex';
            modalTitle.textContent = type === 'in' ? '✅ Punch In Successful' : '✅ Punch Out Successful';
            actionType.textContent = type === 'in' ? 'Punch In' : 'Punch Out';
            modalTime.textContent = timeStr;
          }

          function closeModal() {
            modal.style.display = 'none';
          }

          window.closeModal = closeModal;

          // Start timer
          function startTimer() {
            clearInterval(timerInterval);
            timerInterval = setInterval(() => {
              const now = Date.now();
              const punchIn = parseInt(localStorage.getItem('punchInTime'));
              const diff = now - punchIn;
              elapsedEl.textContent = formatDuration(diff);
            }, 1000);
          }

          // Stop timer
          function stopTimer() {
            clearInterval(timerInterval);
          }

          // Main punch button click
          window.handlePunch = function () {
            const isPunchedIn = localStorage.getItem('isPunchedIn') === 'true';

            if (!isPunchedIn) {
              // Punch In
              const time = new Date();
              const timestamp = time.getTime();
              const timeStr = time.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

              localStorage.setItem('punchInTime', timestamp);
              localStorage.setItem('isPunchedIn', 'true');

              punchBtn.textContent = "Punch Out";
              punchInfo.innerHTML = `🔖 Punched In at <strong>${timeStr}</strong>`;
              elapsedEl.textContent = "00:00:00";
              openModal('in', timeStr);
              startTimer();
            } else {
              // Punch Out
              const punchInTime = parseInt(localStorage.getItem('punchInTime'));
              const now = Date.now();
              const duration = now - punchInTime;
              const timeStr = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

              // Set production time
              const hoursWorked = (duration / 3600000).toFixed(2); // in hrs to 2 decimal
              production.textContent = `Production : ${hoursWorked} hrs`;

              // Update Punch Info
              punchInfo.innerHTML = `🔖 Punched Out at <strong>${timeStr}</strong>`;

              // Clear all
              stopTimer();
              localStorage.removeItem('punchInTime');
              localStorage.setItem('isPunchedIn', 'false');

              punchBtn.textContent = "Punch In";
              openModal('out', timeStr);
            }
          }

          // On page load
          currentTimeEl.textContent = formatNow();

          const isPunchedIn = localStorage.getItem('isPunchedIn') === 'true';
          if (isPunchedIn && localStorage.getItem('punchInTime')) {
            // Resume state
            punchBtn.textContent = "Punch Out";
            const punchIn = parseInt(localStorage.getItem('punchInTime'));
            const timeStr = new Date(punchIn).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
            punchInfo.innerHTML = `🔖 Punched In at <strong>${timeStr}</strong>`;
            startTimer();
          } else {
            punchBtn.textContent = "Punch In";
            elapsedEl.textContent = "00:00:00";
            production.textContent = "Production : 0.00 hrs";
          }
        });



        // Leave Form Logic

        const openFormBtn = document.getElementById('openFormBtn');
        const formOverlay = document.getElementById('formOverlay');
        const leaveForm = document.getElementById('leaveForm');
        const successModal = document.getElementById('submitModal');

        openFormBtn.addEventListener('click', (e) => {
          e.preventDefault();
          formOverlay.style.display = 'flex';
        });

        leaveForm.addEventListener('submit', function (e) {
          e.preventDefault();

          // Simple manual validation
          let isValid = true;
          const inputs = leaveForm.querySelectorAll('input, select, textarea');
          inputs.forEach(input => {
            if (!input.checkValidity()) {
              isValid = false;
              input.style.borderColor = 'red';
            } else {
              input.style.borderColor = '#ccc';
            }
          });

          if (isValid) {
            formOverlay.style.display = 'none';
            successModal.style.display = 'flex';
            leaveForm.reset();
          }
        });

        function closeForm() {
          formOverlay.style.display = 'none';
          leaveForm.reset();
        }

        function closeSuccessModal() {
          successModal.style.display = 'none';
        }




        const ctx = document.getElementById('lineChart').getContext('2d');
        const lineChart = new Chart(ctx, {
          type: 'line',
          data: {
            labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul'],
            datasets: [{
              label: 'Performance',
              data: [20, 20, 35, 35, 40, 60, 60],
              borderColor: '#22c55e',
              backgroundColor: 'rgba(34, 197, 94, 0.2)',
              tension: 0.4,
              fill: true
            }]
          },
          options: {
            plugins: { legend: { display: false } },
            scales: {
              y: { beginAtZero: true }
            }
          }
        });

        // 🗓 Sample 2025 Indian Holidays (you can add more)
        const holidays = [
          { date: '2025-01-26', name: 'Republic Day' },
          { date: '2025-03-17', name: 'Holi' },
          { date: '2025-04-10', name: 'Ram Navami' },
          { date: '2025-04-14', name: 'Ambedkar Jayanti' },
          { date: '2025-05-01', name: 'Labour Day' },
          { date: '2025-08-15', name: 'Independence Day' },
          { date: '2025-09-15', name: 'Milad-un-Nabi' },
          { date: '2025-10-02', name: 'Gandhi Jayanti' },
          { date: '2025-10-20', name: 'Dussehra' },
          { date: '2025-10-31', name: 'Diwali' },
          { date: '2025-12-25', name: 'Christmas' }
        ];

        const monthNames = ["January", "February", "March", "April", "May", "June",
          "July", "August", "September", "October", "November", "December"];

        function groupHolidaysByMonth(holidays) {
          const grouped = {};
          holidays.forEach(h => {
            const month = new Date(h.date).getMonth();
            if (!grouped[month]) grouped[month] = [];
            grouped[month].push(h);
          });
          return grouped;
        }

        function openHolidayModal() {
          const modal = document.getElementById('holidayModal');
          const content = document.getElementById('holidayContent');
          content.innerHTML = '';

          const grouped = groupHolidaysByMonth(holidays);

          Object.keys(grouped).forEach(monthIndex => {
            const monthHolidays = grouped[monthIndex];
            const monthBlock = document.createElement('div');
            const monthTitle = document.createElement('div');
            monthTitle.className = 'month-title';
            monthTitle.textContent = monthNames[monthIndex];
            monthBlock.appendChild(monthTitle);

            monthHolidays.forEach(holiday => {
              const day = new Date(holiday.date).toLocaleDateString('en-IN', {
                day: 'numeric', month: 'short', year: 'numeric', weekday: 'short'
              });
              const item = document.createElement('div');
              item.className = 'holiday-item';
              item.textContent = `${day} - ${holiday.name}`;
              monthBlock.appendChild(item);
            });

            content.appendChild(monthBlock);
          });

          modal.style.display = 'flex';
        }

        function closeHolidayModal() {
          document.getElementById('holidayModal').style.display = 'none';
        }

        function showNextHoliday() {
          const today = new Date();
          const upcoming = holidays.find(h => new Date(h.date) >= today);
          const displayText = upcoming ?
            `${upcoming.name}, ${new Date(upcoming.date).toLocaleDateString('en-IN', {
              day: 'numeric', month: 'short', year: 'numeric'
            })}` :
            'No upcoming holidays';
          document.getElementById('nextHolidayText').textContent = displayText;
        }

        // Initialize
        showNextHoliday();

    </script>

    <script>
        document.getElementById("leaveForm").addEventListener("submit", function (e) {
            e.preventDefault();

            let form = this;

            let newRequest = {
                id: Date.now(),
                leaveType: form.leaveType.value,
                emergencyContact: form.emergencyContact.value,
                startDate: form.startDate.value,
                endDate: form.endDate.value,
                reason: form.reason.value,
                status: "pending"
            };

            let pending = JSON.parse(localStorage.getItem("pendingRequests")) || [];
            pending.push(newRequest);

            localStorage.setItem("pendingRequests", JSON.stringify(pending));

            // Success modal open
            document.getElementById("submitModal").style.display = "flex";

            form.reset();
        });
    </script>



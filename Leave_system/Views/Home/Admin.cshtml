@{
    Layout = null;
}
@* @model List<Leave_system.Models.User> *@
@model Leave_system.Models.AdminViewModel


<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Leave Management Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link href="~/css/adminpage.css" rel="stylesheet" />

</head>

<body>

    <!-- Fixed Navbar -->
    <div class="navbar fixed-navbar">
        <a class="active" href="@Url.Action("Admin", "Home")"><i class="fa fa-fw fa-home"></i> Home</a>
        <a href="#"><i class="fa fa-fw fa-envelope"></i> Profile</a>
        <a href="#"><i class="fa fa-fw fa-envelope"></i> Contact</a>
        <a href="@Url.Action("AdminLogin", "Home")"><i class="fa fa-fw fa-user"></i> Logout</a>
    </div>

    <div class="container" style="margin-top:80px;">
        <div class="top-cards">
            <div class="card">
                <h3>Pending Requests</h3>
                <p class="number" id="pendingCount">0</p>
                <p class="label">Awaiting approval</p>
            </div>
            <div class="card">
                <h3>Team Members</h3>
                <p class="number" id="teamCount">0</p>
                <p class="label">Active employees</p>
            </div>
            <div class="card">
                <h3>Today Attendance</h3>
                <p class="number" id="attendanceCount">0</p>
                <p class="label">Today Present Employee</p>
            </div>
        </div>




        <script>
                     function updateTopCards() {
                // Pending Requests
                let pendingLeaves = document.querySelectorAll('#pendingContainer .leave-card').length;
                document.getElementById('pendingCount').textContent = pendingLeaves;

                // Team Members
                let teamRows = document.querySelectorAll('#teamSection table.team-table tbody tr').length;
                document.getElementById('teamCount').textContent = teamRows;

                // Today Attendance
                let attendanceRows = document.querySelectorAll('#attendanceTable tbody tr').length;
                document.getElementById('attendanceCount').textContent = attendanceRows;
            }

            // Call it on page load
            window.addEventListener('load', updateTopCards);

            // Optional: Call it after any approve/reject action if items change dynamically

        </script>

        <div class="tabs">
            <button class="tab active">Pending Requests</button>
            <button class="tab" onclick="showTeam()">Team Overview</button>
            <button class="tab">Reports</button>
            <button class="tab" id="attendanceTab">Attendance</button>
        </div>


        <div class="section" id="pendingSection">
            <h2>Pending Leave Requests</h2>
            <p class="subtitle">Review and approve employee leave applications</p>

            <!-- ================= Success Message ================= -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert success">
                    @TempData["SuccessMessage"]
                </div>
            }

            <!-- ================= Leave Form ================= -->
            <div id="leaveFormContainer">
                <h3 id="formTitle">Apply for Leave</h3>

                <form asp-action="SaveLeave" method="post" class="leave-form">
                    <input type="hidden" name="Id" id="leaveId" />
                    <div class="form-group">
                        <label>Select User</label>
                        <select id="userSelect" name="UserId" required onchange="fillUserName()">
                            <option value="">-- Select User --</option>
                            @foreach (var u in Model.Users)
                            {
                                <option value="@u.Id"
                                        data-fname="@u.FirstName"
                                        data-lname="@u.LastName">
                                    @u.FirstName @u.LastName
                                </option>
                            }
                        </select>
                    </div>

                    <div class="form-group">
                        <input type="text" id="firstName" readonly />
                        <label>First Name</label>
                    </div>

                    <div class="form-group">
                        <input type="text" id="lastName" readonly />
                        <label>Last Name</label>
                    </div>

                    <div class="form-group">
                        <label for="leaveType">Leave Type</label>
                        <select name="LeaveType" id="leaveType" required>
                            <option value="">--Select--</option>
                            <option value="Casual">Casual</option>
                            <option value="Sick">Sick</option>
                            <option value="Emergency">Emergency</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <input type="text" name="EmergencyContact" id="emergencyContact" required />
                        <label for="emergencyContact">Emergency Contact</label>
                    </div>

                    <div class="form-group">
                        <input type="date" name="StartDate" id="startDate" required />
                        <label for="startDate">Start Date</label>
                    </div>

                    <div class="form-group">
                        <input type="date" name="EndDate" id="endDate" required />
                        <label for="endDate">End Date</label>
                    </div>

                    <div class="form-group">
                        <textarea name="Reason" id="reason" rows="3" required></textarea>
                        <label for="reason">Reason</label>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn btn-save">Save Leave</button>
                        <button type="button" class="btn btn-reset" onclick="resetForm()">Reset</button>
                    </div>
                </form>
            </div>

            <!-- ================= Pending Leaves ================= -->
            <div id="pendingContainer">
                @if (Model.PendingLeaves != null && Model.PendingLeaves.Any())
                {
                    foreach (var item in Model.PendingLeaves)
                    {
                        <div class="leave-card" data-id="@item.Id">
                            <div class="leave-header">
                                <div>
                                    <h3>@item.FirstName @item.LastName</h3>
                                    <p>Engineering</p>
                                </div>
                                <span class="badge">@item.LeaveType</span>
                            </div>

                            <div class="leave-info">
                                <div>
                                    <strong>Duration</strong>
                                    <p>@item.StartDate?.ToString("dd/MM/yyyy") - @item.EndDate?.ToString("dd/MM/yyyy")</p>
                                </div>
                                <div>
                                    <strong>Applied Date</strong>
                                    <p>@item.CreatedAt.ToString("dd/MM/yyyy")</p>
                                </div>
                            </div>

                            <div class="reason">
                                Reason: @item.Reason
                            </div>

                            <div class="actions">
                                <button class="btn approve" onclick="approveLeave(@item.Id)">✔ Approve</button>
                                <button class="btn reject" onclick="rejectLeave(@item.Id)">✖ Reject</button>
                                <button class="btn details" onclick="viewDetails(@item.Id)">View Details</button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p>No pending leaves</p>
                }
            </div>
        </div>


        <div id="teamSection" class="section" style="display:none;">
            <h2>Team Overview</h2>
            <p class="subtitle">All registered employees</p>

            <!-- ================= USER FORM ================= -->
            <form method="post" action="/Home/SaveUser" class="user-form" autocomplete="off">

                <input type="hidden" name="Id" id="UserId" />

                <div class="form-group">
                    <input type="text" name="FirstName" id="FirstName" autocomplete="off" required />
                    <label>First Name</label>
                </div>

                <div class="form-group">
                    <input type="text" name="LastName" id="LastName" autocomplete="off" required />
                    <label>Last Name</label>
                </div>

                <div class="form-group">
                    <input type="email" name="Email" id="Email" autocomplete="off" required />
                    <label>Email</label>
                </div>

                <div class="form-group">
                    <input type="text" name="Phone" id="Phone" autocomplete="off" required />
                    <label>Phone</label>
                </div>

                <div class="form-group password-group">
                    <input type="password" name="Password" id="Password" autocomplete="off" required />
                    <label>Password</label>
                    <span class="toggle-password" onclick="togglePassword()">👁️</span>
                </div>

                <button type="submit">Save User</button>
                <button type="button" onclick="clearForm()">Clear</button>

            </form>


            <!-- ================= USERS TABLE ================= -->
            <table class="team-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Password</th>
                        <th>Joined On</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr>
                            <td>@user.FirstName @user.LastName</td>
                            <td>@user.Email</td>
                            <td>@user.Phone</td>
                            <td>@user.Password</td>
                            <td>@user.JoinedOn.ToString("dd MMM yyyy")</td>
                            <td>
                                <button type="button" onclick="editUser(
                                        '@user.Id',
                                        '@user.FirstName',
                                        '@user.LastName',
                                        '@user.Email',
                                        '@user.Phone',
                                        '@user.Password'
                                    )">
                                    ✏️
                                </button>

                                <a href="/Home/DeleteUser/@user.Id"
                                   onclick="return confirm('Delete this user?')">🗑️</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div id="reportsSection" class="section" style="display:none;">
            <h2>Reports</h2>
            <button onclick="downloadExcel()"
                    style="padding:8px 15px; background:blue; color:#fff; border:none; cursor:pointer;">
                ⬇ Download Excel
            </button>

            <button onclick="deleteAllReports()"
                    style="padding:8px 15px; background:red; color:#fff; border:none; cursor:pointer; margin-left:10px;">
                🗑 Delete All
            </button>

            <div style="margin-top: 20px;">
                <table id="reportsTable" border="1" cellspacing="0" cellpadding="5" style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr>
                            <th>Full Name</th>
                            <th>Leave Type</th>
                            <th>Contact</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Reason</th>
                            <th>Applied On</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="reportsTableBody">
                        <!-- Rows will be injected here -->
                    </tbody>
                </table>
            </div>
        </div>


        <div id="attendanceSection" class="section" style="display:none;">
            <h2>Attendance</h2>
            <p class="subtitle">Employee attendance records</p>

            <table id="attendanceTable" border="1" cellspacing="0" cellpadding="5" style="width:100%; border-collapse: collapse;">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>User Name</th>
                        <th>Punch In Date</th>
                        <th>Punch In Time</th>
                        <th>Punch Out Date</th>
                        <th>Punch Out Time</th>
                        <th>Work Hours</th>
                    </tr>
                </thead>
                <tbody id="attendanceTableBody">
                    <!-- Rows from DB will go here -->
                </tbody>
            </table>
        </div>

    </div>




    <!-- SUCCESS MODAL -->
    <div id="successModal" class="modal">
        <div class="modal-content">
            <h3 id="successTitle">Success</h3>
            <p id="successMessage"></p>
            <button onclick="closeModal()" class="close-btn">OK</button>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div id="successPopup" class="success-popup">
            ✔ @TempData["SuccessMessage"]
        </div>
    }
    <script>
        setTimeout(() => {
            const popup = document.getElementById("successPopup");
            if (popup) popup.style.display = "none";
        }, 3000);


        function togglePassword() {
            const pwd = document.getElementById("Password");
            pwd.type = pwd.type === "password" ? "text" : "password";
        }
                window.onload = function () {
            document.getElementById("Email").value = "";
            document.getElementById("Password").value = "";
        };
    </script>


    <div id="detailsModal" class="modal">
        <div class="modal-content">
            <h2>Leave Details</h2>

            <label>Name:</label>
            <input id="dName" type="text">

            <label>Department:</label>
            <input id="dDept" type="text">

            <label>Leave Type:</label>
            <input id="dType" type="text">

            <label>Duration:</label>
            <input id="dDuration" type="text">

            <label>Applied Date:</label>
            <input id="dApplied" type="text">

            <label>Reason:</label>
            <textarea id="dReason"></textarea>

            <button onclick="saveChanges()" class="btn approve">Save</button>
            <button onclick="closeDetailsModal()" class="btn reject">Cancel</button>
        </div>
    </div>


    <script>
                      function loadAttendance() {
            fetch('/Attendance/GetAttendance')
                .then(res => res.json())
                .then(data => {
                    console.log(data);
                    let rowsHTML = "";

                            data.forEach(a => {
            rowsHTML += `
                <tr>
                    <td>${a.attendanceId}</td>
                    <td>${a.fullName}</td>
                    <td>${a.punchInDate}</td>
                    <td>${a.punchInTime}</td>
                    <td>${a.punchOutDate || ''}</td>
                    <td>${a.punchOutTime || ''}</td>
                    <td>${a.workHours || ''}</td>
                </tr>
            `;
        });


                    document.getElementById("attendanceTableBody").innerHTML = rowsHTML;
                })
                .catch(err => console.error("Error loading attendance:", err));
        }


                    const attendanceSection = document.getElementById("attendanceSection");
        const attendanceTab = document.getElementById("attendanceTab");

        attendanceTab.addEventListener("click", () => {
            hideAllSections();
            attendanceTab.classList.add("active");
            attendanceSection.style.display = "block";
            loadAttendance(); 
        });


    </script>



    <script>
        const tabs = document.querySelectorAll(".tab");

        const pendingSection = document.getElementById("pendingSection");
        const teamSection = document.getElementById("teamSection");
        const reportsSection = document.getElementById("reportsSection");

        function hideAllSections() {
            pendingSection.style.display = "none";
            teamSection.style.display = "none";
            reportsSection.style.display = "none";
             attendanceSection.style.display = "none";

            tabs.forEach(t => t.classList.remove("active"));
        }

        // Pending Tab
        tabs[0].addEventListener("click", () => {
            hideAllSections();
            tabs[0].classList.add("active");
            pendingSection.style.display = "block";
        });

        // Team Overview Tab
        function showTeam() {
            hideAllSections();
            tabs[1].classList.add("active");
            teamSection.style.display = "block";
        }

        // Reports Tab
        tabs[2].addEventListener("click", () => {
            hideAllSections();
            tabs[2].classList.add("active");
            reportsSection.style.display = "block";
            loadReports();
        });

                function editUser(id, fname, lname, email, phone, password) {
                showTeam(); // Team tab auto open

                document.getElementById("UserId").value = id;
                document.getElementById("FirstName").value = fname;
                document.getElementById("LastName").value = lname;
                document.getElementById("Email").value = email;
                document.getElementById("Phone").value = phone;
                document.getElementById("Password").value = password;
            }

            function clearForm() {
                document.getElementById("UserId").value = "";
                document.getElementById("FirstName").value = "";
                document.getElementById("LastName").value = "";
                document.getElementById("Email").value = "";
                document.getElementById("Phone").value = "";
                document.getElementById("Password").value = "";
            }
    </script>

    <script>
                function fillUserName() {
            const select = document.getElementById("userSelect");
            const option = select.options[select.selectedIndex];

            document.getElementById("firstName").value = option.getAttribute("data-fname") || "";
            document.getElementById("lastName").value = option.getAttribute("data-lname") || "";
        }

                function saveLeave() {
            const model = {
                Id: parseInt(document.getElementById("leaveId").value || 0),
                FirstName: document.getElementById("firstName").value,
                LastName: document.getElementById("lastName").value,
                LeaveType: document.getElementById("leaveType").value,
                EmergencyContact: document.getElementById("emergencyContact").value,
                StartDate: document.getElementById("startDate").value,
                EndDate: document.getElementById("endDate").value,
                Reason: document.getElementById("reason").value
            };

            fetch('/Home/SaveLeave', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(model)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert('Leave saved successfully');
                    resetForm();
                    location.reload(); // Reload to show updated pending leaves
                } else {
                    alert('Error saving leave');
                }
            });
        }

        function viewDetails(id) {
            const card = document.querySelector(`.leave-card[data-id='${id}']`);
            document.getElementById("leaveId").value = id;
            document.getElementById("firstName").value = card.querySelector("h3").innerText.split(' ')[0];
            document.getElementById("lastName").value = card.querySelector("h3").innerText.split(' ')[1];
            document.getElementById("leaveType").value = card.querySelector(".badge").innerText;
            document.getElementById("emergencyContact").value = card.querySelector(".leave-info div:nth-child(2) p").innerText; // adapt if you store differently
            document.getElementById("startDate").value = card.querySelector(".leave-info div:first-child p").innerText.split(' - ')[0].split('/').reverse().join('-');
            document.getElementById("endDate").value = card.querySelector(".leave-info div:first-child p").innerText.split(' - ')[1].split('/').reverse().join('-');
            document.getElementById("reason").value = card.querySelector(".reason").innerText.replace('Reason: ', '');
            document.getElementById("formTitle").innerText = "Edit Leave Request";
        }

                function resetForm() {
            document.getElementById("leaveId").value = "";
            document.getElementById("firstName").value = "";
            document.getElementById("lastName").value = "";
            document.getElementById("leaveType").value = "";
            document.getElementById("emergencyContact").value = "";
            document.getElementById("startDate").value = "";
            document.getElementById("endDate").value = "";
            document.getElementById("reason").value = "";
            document.getElementById("formTitle").innerText = "Apply for Leave";
        }


    </script>


    <script>
                function formatDate(date) {
            if (!date) return "";
            return new Date(date).toLocaleDateString('en-GB');
        }

        function loadReportsFromDB() {
            fetch('/Home/GetReports')
                .then(res => res.json())
                .then(data => {
                    let rowsHTML = "";

                    data.forEach(r => {
                        let statusColor =
                            r.status === "Approved" ? "green" :
                            r.status === "Rejected" ? "red" : "black";

                        rowsHTML += `
                            <tr>
                                <td>${r.firstName} ${r.lastName}</td>
                                <td>${r.leaveType}</td>
                                <td>${r.emergencyContact}</td>
                                <td>${formatDate(r.startDate)}</td>
                                <td>${formatDate(r.endDate)}</td>
                                <td>${r.reason}</td>
                                <td>${formatDate(r.createdAt)}</td>
                                <td style="color:${statusColor}; font-weight:bold;">
                                    ${r.status}
                                </td>
                            </tr>
                        `;
                    });

                    document.getElementById("reportsTableBody").innerHTML = rowsHTML;
                });
        }

        loadReportsFromDB();

    </script>


    <script>
        function approveLeave(id) {
            updateLeaveStatus(id, "Approved");
        }

        function rejectLeave(id) {
            updateLeaveStatus(id, "Rejected");
        }

        function updateLeaveStatus(id, status) {
            fetch('/Home/UpdateLeaveStatus', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: id, status: status })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    // card remove
                    document.querySelector(`[data-id='${id}']`).remove();
                    updatePendingCount();

                    // success modal
                    document.getElementById("successTitle").innerText = status;
                    document.getElementById("successMessage").innerText =
                        `Application ${status} successfully`;
                    document.getElementById("successModal").style.display = "block";

                    // Reports reload
                    loadReportsFromDB();
                }
            });
        }
    </script>


    <script>
                // ---------------------- DOWNLOAD EXCEL ----------------------
        function downloadExcel() {
            let reports = JSON.parse(localStorage.getItem("reports")) || [];

            if (reports.length === 0) {
                alert("No reports available to download.");
                return;
            }

            // Excel Header
            let csv = "Name,Department,Leave Type,Duration,Applied Date,Reason,Status,Date\n";

            // Add row for each record
            reports.forEach(r => {
                csv += `${r.name},${r.dept},${r.type},${r.duration},${r.applied},${r.reason},${r.status},${r.date}\n`;
            });

            // Convert CSV to downloadable Excel file
            let blob = new Blob([csv], { type: "application/vnd.ms-excel" });
            let url = URL.createObjectURL(blob);

            let a = document.createElement("a");
            a.href = url;
            a.download = "Reports_Data.xls";   // Excel file name
            a.click();

            URL.revokeObjectURL(url);
        }



        // ---------------------- DELETE ALL REPORTS ----------------------
        function deleteAllReports() {
            if (!confirm("Are you sure you want to delete all report records?")) return;

            localStorage.removeItem("reports"); // delete from storage

            // Clear UI
            document.getElementById("approvedList").innerHTML = "";
            document.getElementById("rejectedList").innerHTML = "";

            alert("All reports deleted successfully!");
        }

    </script>
</body>

</html>

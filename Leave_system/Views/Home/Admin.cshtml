@{
    Layout = null;
}
@* @model List<Leave_system.Models.User> *@
@model Leave_system.Models.AdminViewModel


<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Leave Management Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        /* Attractive gradient background for the whole page */
        body {
            background: linear-gradient(135deg, #f8fafc 0%, #e0e7ff 50%, #c7d2fe 100%);
            min-height: 100vh;
            font-family: 'Inter', sans-serif;
            margin: 0;
        }

        /* Add a subtle shadow and rounded corners to main container */
        .container {
            background: rgba(255,255,255,0.85);
            border-radius: 24px;
            box-shadow: 0 8px 32px rgba(60, 72, 107, 0.12);
            padding: 32px;
            margin: 40px auto;
            max-width: 1200px;
            margin-top: 80px; /* Add margin-top to avoid overlap with fixed navbar */
        }

        /* Navbar styling */
        .navbar {
            background: rgba(30, 41, 59, 0.95);
            color: #fff;
            padding: 18px 32px;
            border-radius: 0 0 18px 18px;
            display: flex;
            justify-content: flex-start;
            align-items: center;
            gap: 24px;
            font-size: 1.1rem;
            box-shadow: 0 2px 8px rgba(30,41,59,0.08);
        }

        /* Make navbar fixed to top */
        .fixed-navbar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            z-index: 100;
            border-radius: 0 0 18px 18px;
            box-shadow: 0 2px 8px rgba(30,41,59,0.08);
        }

        /* Navbar links */
        .navbar a {
            color: #fff;
            text-decoration: none;
            padding: 8px 18px;
            border-radius: 8px;
            transition: background 0.2s;
        }

            .navbar a.active, .navbar a:hover {
                background: #6366f1;
            }

        /* Top cards styling */
        .top-cards {
            display: flex;
            gap: 32px;
            margin-bottom: 32px;
        }

        .card {
            background: linear-gradient(120deg, #e0e7ff 60%, #f1f5f9 100%);
            border-radius: 18px;
            box-shadow: 0 4px 16px rgba(99,102,241,0.08);
            padding: 28px 36px;
            flex: 1;
            text-align: left;
        }

            .card h3 {
                margin: 0 0 8px 0;
                font-weight: 600;
                color: #3730a3;
            }

            .card .number {
                font-size: 2.5rem;
                font-weight: 700;
                color: #6366f1;
            }

            .card .label {
                color: #64748b;
                font-size: 1rem;
            }

        /* Tabs styling */
        .tabs {
            display: flex;
            gap: 12px;
            margin-bottom: 24px;
        }

        .tab {
            background: #e0e7ff;
            color: #3730a3;
            border: none;
            border-radius: 8px 8px 0 0;
            padding: 12px 32px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s;
        }

            .tab.active, .tab:hover {
                background: #6366f1;
                color: #fff;
            }

        /* Section styling */
        .section {
            background: rgba(243,244,246,0.7);
            border-radius: 18px;
            padding: 32px;
            box-shadow: 0 2px 12px rgba(99,102,241,0.06);
        }

        /* Leave card styling */
        .leave-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 2px 12px rgba(99,102,241,0.08);
            margin: 20px;
            padding: 28px 32px;
            transition: box-shadow 0.2s;
        }

            .leave-card:hover {
                box-shadow: 0 6px 24px rgba(99,102,241,0.16);
            }

        .leave-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }

            .leave-header h3 {
                margin: 0;
                font-size: 1.3rem;
                font-weight: 700;
                color: #3730a3;
            }

            .leave-header p {
                margin: 0;
                color: #64748b;
            }

        .badge {
            background: #fef3c7;
            color: #b45309;
            border-radius: 8px;
            padding: 6px 18px;
            font-weight: 600;
            font-size: 1rem;
        }

        .leave-info {
            display: flex;
            gap: 48px;
            margin-bottom: 10px;
        }

            .leave-info strong {
                color: #6366f1;
            }

        .reason {
            background: #f1f5f9;
            border-radius: 8px;
            padding: 12px 18px;
            margin-bottom: 16px;
            color: #334155;
            font-size: 1.05rem;
        }

        .actions {
            display: flex;
            gap: 18px;
        }

        .btn {
            border: none;
            border-radius: 8px;
            padding: 10px 28px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.2s, color 0.2s;
        }

            .btn.approve {
                background: #22c55e;
                color: #fff;
            }

            .btn.reject {
                background: #ef4444;
                color: #fff;
            }

            .btn.details {
                background: #6366f1;
                color: #fff;
            }

            .btn.logout {
                background: #3730a3;
                color: #fff;
                font-size: 1rem;
                padding: 10px 24px;
                border-radius: 8px;
                font-weight: 600;
                border: none;
                cursor: pointer;
                box-shadow: 0 2px 8px rgba(99,102,241,0.08);
                transition: background 0.2s;
            }

                .btn.logout:hover {
                    background: #57534e;
                }

        /* Responsive adjustments */
        @@media screen and (max-width: 768px) {
            .top-cards {
                flex-direction: column;
                gap: 20px;
            }

            .card {
                padding: 20px;
            }

            .navbar {
                flex-direction: column;
                padding: 12px;
            }

                .navbar a {
                    padding: 10px;
                    font-size: 1rem;
                }

            .tabs {
                flex-wrap: wrap;
            }

            .tab {
                flex: 1 1 100%;
                text-align: center;
            }

            .section {
                padding: 24px;
            }

            .leave-card {
                padding: 20px;
            }

            .btn {
                width: 100%;
                padding: 12px;
                font-size: 1rem;
            }
        }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.6);
            z-index: 999;
        }

        .modal-content {
            background: #fff;
            padding: 25px;
            margin: 10% auto;
            width: 400px;
            border-radius: 10px;
        }

        .close-btn {
            margin-top: 15px;
            width: 100%;
            padding: 10px;
            background: #4CAF50;
            border: none;
            border-radius: 5px;
            color: white;
        }

        .reportslistsection{
            display:flex;
            gap: 35px;
        }

        .team-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

            .team-table th, .team-table td {
                padding: 12px;
                border: 1px solid #ddd;
                text-align: left;
            }

            .team-table th {
                background: #1a1f36;
                color: white;
            }

            .team-table tr:hover {
                background: #f5f5f5;
            }

    </style>
    
</head>

<body>

    <!-- Fixed Navbar -->
    <div class="navbar fixed-navbar">
        <a class="active" href="@Url.Action("Admin", "Home")"><i class="fa fa-fw fa-home"></i> Home</a>
        <a href="#"><i class="fa fa-fw fa-envelope"></i> Profile</a>
        <a href="#"><i class="fa fa-fw fa-envelope"></i> Contact</a>
        <a href="@Url.Action("AdminLogin", "Home")"><i class="fa fa-fw fa-user"></i> Logout</a>
    </div>

    <div class="container" style="margin-top:80px;">
        <div class="top-cards">
            <div class="card">
                <h3>Pending Requests</h3>
                <p class="number"> </p>
                <p class="label">Awaiting approval</p>
            </div>
            <div class="card">
                <h3>Team Members</h3>
                <p class="number">12</p>
                <p class="label">Active employees</p>
            </div>
            <div class="card">
                <h3>This Month</h3>
                <p class="number">8</p>
                <p class="label">Approved requests</p>
            </div>
        </div>

        <div class="tabs">
            <button class="tab active">Pending Requests</button>
            <button class="tab" onclick="showTeam()">Team Overview</button>
            <button class="tab">Reports</button>
            <button class="tab">Attendance</button>
        </div>
        

        <div class="section" id="pendingSection">
            <h2>Pending Leave Requests</h2>

            <p class="subtitle">Review and approve employee leave applications</p>
            <div id="pendingContainer"></div>

            @if (Model.PendingLeaves != null && Model.PendingLeaves.Any())
            {
                foreach (var item in Model.PendingLeaves)
                {
                    <div class="leave-card" data-id="@item.Id">
                        <div class="leave-header">
                            <div>
                                <h3>@item.FirstName @item.LastName</h3>

                                <p>Engineering</p>
                            
                            </div>
                            <span class="badge">@item.LeaveType</span>
                        </div>

                        <div class="leave-info">
                            <div>
                            <strong>Duration</strong>
                            <p>
                                @item.StartDate?.ToString("dd/MM/yyyy")
                                -
                                @item.EndDate?.ToString("dd/MM/yyyy")
                                </p>
                            </div>
                            <div>
                            <strong>Applied Date</strong>
                            <p>@item.CreatedAt.ToString("dd/MM/yyyy")</p>
                            </div>
                        </div>

                        <div class="reason">
                            Reason: @item.Reason
                        </div>

                        <div class="actions">
                            <button class="btn approve" onclick="approveLeave(@item.Id)">✔ Approve</button>
                            <button class="btn reject" onclick="rejectLeave(@item.Id)">✖ Reject</button>
                            <button class="btn details" onclick="viewDetails(this)">View Details</button>
                        </div>
                    </div>
                }
            }
            else
            {
                <p>No pending leaves</p>
            }

        </div>
   
        <div id="teamSection" class="section" style="display:none;">
            <h2>Team Overview</h2>
            <p class="subtitle">All registered employees</p>

         
            <table class="team-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Joined On</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model.Users != null && Model.Users.Any())
                    {
                        foreach (var user in Model.Users)
                        {
                            <tr>
                                <td>@user.FirstName @user.LastName</td>
                                <td>@user.Email</td>
                                <td>@user.Phone</td>
                                <td>@user.JoinedOn.ToString("dd MMM yyyy")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" style="text-align:center;">No users found</td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>


        
        <div id="reportsSection" class="section" style="display:none;">
            <h2>Reports</h2>
            <button onclick="downloadExcel()"
                    style="padding:8px 15px; background:blue; color:#fff; border:none; cursor:pointer;">
                ⬇ Download Excel
            </button>

            <button onclick="deleteAllReports()"
                    style="padding:8px 15px; background:red; color:#fff; border:none; cursor:pointer; margin-left:10px;">
                🗑 Delete All
            </button>

            <div style="margin-top: 20px;">
                <table id="reportsTable" border="1" cellspacing="0" cellpadding="5" style="width: 100%; border-collapse: collapse;">
                    <thead style="background-color: #f0f0f0;">
                        <tr>
                            <th>Full Name</th>
                            <th>Leave Type</th>
                            <th>Contact</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Reason</th>
                            <th>Applied On</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="reportsTableBody">
                        <!-- Rows will be injected here -->
                    </tbody>
                </table>
            </div>
        </div>

  

            </div>
     </div>
        



    <!-- SUCCESS MODAL -->
    <div id="successModal" class="modal">
        <div class="modal-content">
            <h3 id="successTitle">Success</h3>
            <p id="successMessage"></p>
            <button onclick="closeModal()" class="close-btn">OK</button>
        </div>
    </div>

    <!-- DETAILS + EDIT MODAL -->
    <div id="detailsModal" class="modal">
        <div class="modal-content">
            <h2>Leave Details</h2>

            <label>Name:</label>
            <input id="dName" type="text">

            <label>Department:</label>
            <input id="dDept" type="text">

            <label>Leave Type:</label>
            <input id="dType" type="text">

            <label>Duration:</label>
            <input id="dDuration" type="text">

            <label>Applied Date:</label>
            <input id="dApplied" type="text">

            <label>Reason:</label>
            <textarea id="dReason"></textarea>

            <button onclick="saveChanges()" class="btn approve">Save</button>
            <button onclick="closeDetailsModal()" class="btn reject">Cancel</button>
        </div>
    </div>
    <script>
    const tabs = document.querySelectorAll(".tab");

    const pendingSection = document.getElementById("pendingSection");
    const teamSection = document.getElementById("teamSection");
    const reportsSection = document.getElementById("reportsSection");

    function hideAllSections() {
        pendingSection.style.display = "none";
        teamSection.style.display = "none";
        reportsSection.style.display = "none";

        tabs.forEach(t => t.classList.remove("active"));
    }

    // Pending Tab
    tabs[0].addEventListener("click", () => {
        hideAllSections();
        tabs[0].classList.add("active");
        pendingSection.style.display = "block";
    });

    // Team Overview Tab
    function showTeam() {
        hideAllSections();
        tabs[1].classList.add("active");
        teamSection.style.display = "block";
    }

    // Reports Tab
    tabs[2].addEventListener("click", () => {
        hideAllSections();
        tabs[2].classList.add("active");
        reportsSection.style.display = "block";
        loadReports();
    });
</script>
    <script>
                function formatDate(date) {
            if (!date) return "";
            return new Date(date).toLocaleDateString('en-GB');
        }

        function loadReportsFromDB() {
            fetch('/Home/GetReports')
                .then(res => res.json())
                .then(data => {
                    let rowsHTML = "";

                    data.forEach(r => {
                        let statusColor =
                            r.status === "Approved" ? "green" :
                            r.status === "Rejected" ? "red" : "black";

                        rowsHTML += `
                            <tr>
                                <td>${r.firstName} ${r.lastName}</td>
                                <td>${r.leaveType}</td>
                                <td>${r.emergencyContact}</td>
                                <td>${formatDate(r.startDate)}</td>
                                <td>${formatDate(r.endDate)}</td>
                                <td>${r.reason}</td>
                                <td>${formatDate(r.createdAt)}</td>
                                <td style="color:${statusColor}; font-weight:bold;">
                                    ${r.status}
                                </td>
                            </tr>
                        `;
                    });

                    document.getElementById("reportsTableBody").innerHTML = rowsHTML;
                });
        }

        loadReportsFromDB();

    </script>


    <script>
        function approveLeave(id) {
            updateLeaveStatus(id, "Approved");
        }

        function rejectLeave(id) {
            updateLeaveStatus(id, "Rejected");
        }

        function updateLeaveStatus(id, status) {
            fetch('/Home/UpdateLeaveStatus', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id: id, status: status })
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    // card remove
                    document.querySelector(`[data-id='${id}']`).remove();
                    updatePendingCount();

                    // success modal
                    document.getElementById("successTitle").innerText = status;
                    document.getElementById("successMessage").innerText =
                        `Application ${status} successfully`;
                    document.getElementById("successModal").style.display = "block";

                    // Reports reload
                    loadReportsFromDB();
                }
            });
        }
    </script>

        
    <script>
                    // ---------------------- DOWNLOAD EXCEL ----------------------
            function downloadExcel() {
                let reports = JSON.parse(localStorage.getItem("reports")) || [];

                if (reports.length === 0) {
                    alert("No reports available to download.");
                    return;
                }

                // Excel Header
                let csv = "Name,Department,Leave Type,Duration,Applied Date,Reason,Status,Date\n";

                // Add row for each record
                reports.forEach(r => {
                    csv += `${r.name},${r.dept},${r.type},${r.duration},${r.applied},${r.reason},${r.status},${r.date}\n`;
                });

                // Convert CSV to downloadable Excel file
                let blob = new Blob([csv], { type: "application/vnd.ms-excel" });
                let url = URL.createObjectURL(blob);

                let a = document.createElement("a");
                a.href = url;
                a.download = "Reports_Data.xls";   // Excel file name
                a.click();

                URL.revokeObjectURL(url);
            }



            // ---------------------- DELETE ALL REPORTS ----------------------
            function deleteAllReports() {
                if (!confirm("Are you sure you want to delete all report records?")) return;

                localStorage.removeItem("reports"); // delete from storage

                // Clear UI
                document.getElementById("approvedList").innerHTML = "";
                document.getElementById("rejectedList").innerHTML = "";

                alert("All reports deleted successfully!");
            }

    </script>
</body>

</html>
